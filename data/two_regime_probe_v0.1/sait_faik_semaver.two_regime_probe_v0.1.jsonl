{"book_id": "sait_faik_semaver", "story_title": "SEMAVER", "story_id": "sait_faik_semaver__semaver", "paragraph_id": "sait_faik_semaver__semaver_p001", "paragraph_index": 1, "total_paragraphs": 21, "text": "— Sabah ezanı okundu. Kalk yavrum, işe geç kalacaksın. Ali nihayet iş bulmuştu. Bir haftadır fabrikaya gidiyordu. Anası memnundu. Namazını kılmış, duasını yapmıştı. İçindeki Cenabı Hak'la beraber oğlunun odasına girince uzun boyu, geniş vücudu ve çok genç çehresi ile rüyasında makineler, elektrik pilleri, ampuller gören, makine yağları sürünen ve bir dizel motoru homurtusu işiten oğlunu evvela uyandırmaya kıyamadı. Ali işten çıkmış gibi terli ve pembe idi. Halıcıoğlu'ndaki fabrikanın bacası kafasını kaldırmış, bir horoz vekarıyla sabaha, Kâğıthane sırtlarında beliren fecri kâzibe bakıyordu. Neredeyse ötecekti.", "micro_block_id": "sait_faik_semaver__semaver_p001_mb01", "parent_paragraph_id": "sait_faik_semaver__semaver_p001", "is_micro_block": true, "stage": "2.1", "dialogue_char_ratio": 1.0, "dialogue_sentence_ratio": 1.0, "has_dialogue": true, "token_count": 98, "noun_ratio": 0.3673, "verb_ratio": 0.2143, "adj_ratio": 0.1224, "adv_ratio": 0.0612, "non_finite_verb_ratio": 0.0714, "tense_mode": "past", "tense_distribution": {"past": 0.65, "present": 0.0, "aorist": 0.35}, "tense_confidence": 0.65, "scene_segments": {"scenes": [{"scene_index": 1, "scene_type": "single_scene", "split_reason": "structural_fallback"}]}, "scene_source": "llm_dynamic", "fallback_review": {"eligible_for_llm_refinement": false, "reason": "below_token_threshold", "token_count": 98}, "id_normalized": false, "triage_candidate": true, "triage_reasons": ["has_dialogue"], "triage_stage": "05_00_record_normalization_and_selection", "triage_version": "scene_description_v2", "state_identity_profile": {"top_states": [["transition_movement", 0.7484], ["observational_scrutiny", 0.7451], ["nature_reflection", 0.74]], "all_scores": [["transition_movement", 0.7484], ["observational_scrutiny", 0.7451], [