{"book_id": "sait_faik_sarnic", "story_title": "SARNIÇ", "story_id": "sait_faik_sarnic__sarnic", "paragraph_id": "sait_faik_sarnic__sarnic_p001", "paragraph_index": 1, "total_paragraphs": 22, "text": "Dağın eteğine beyaz minareleriyle sarılmış bu şehrin lisesi, zaman geçtikçe daha canlı, daha berrak hatıralarla bize döner, bizi tekrardan içine alırdı. Biz, herhangi bir sınıftık. Herhangi bir son sınıf olduk... Ön avlusu, aynı zamanda burunları, kolları kırık heykellerle süslü bir müze bahçesi, ancak son sınıf talebeleriyle muallimlerin gezindiği bir yer olan liseyi, bir gün ardımıza dönüp bakmadan başkalarına bıraktık. Bir daha buraya ömrümüzün sonuna kadar talebe olarak giremeyeceğimizi bile bile. Bu müthiş bir şeydi! Biz ne kadar seviniyorduk!.. Sanıyorduk ki, mütemadiyen bir güzel şeyi geride bırakacak, bir daha ona sürünemeyecek, onun içine giremeyecek, bir anı bir daha yaşayamayacaktık.", "micro_block_id": "sait_faik_sarnic__sarnic_p001_mb01", "parent_paragraph_id": "sait_faik_sarnic__sarnic_p001", "is_micro_block": true, "stage": "2.1", "dialogue_char_ratio": 0.0, "dialogue_sentence_ratio": 0.0, "has_dialogue": false, "token_count": 120, "noun_ratio": 0.3083, "verb_ratio": 0.1667, "adj_ratio": 0.1, "adv_ratio": 0.0667, "non_finite_verb_ratio": 0.0333, "tense_mode": "aorist", "tense_distribution": {"past": 0.167, "present": 0.0, "aorist": 0.833}, "tense_confidence": 0.833, "scene_segments": {"scenes": [{"scene_index": 1, "scene_type": "single_scene", "split_reason": "structural_fallback"}]}, "scene_source": "llm_dynamic", "fallback_review": {"eligible_for_llm_refinement": false, "reason": "below_token_threshold", "token_count": 120}, "id_normalized": false, "triage_candidate": true, "triage_reasons": ["token_strong_scene", "descriptive_block"], "triage_stage": "05_00_record_normalization_and_selection", "triage_version": "scene_description_v2", "state_identity_profile": {"top_states": [["nature_reflection", 0.7637], ["imaginative_escapism", 0.7531], ["transitio