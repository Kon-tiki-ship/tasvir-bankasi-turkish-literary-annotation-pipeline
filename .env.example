# Copy this file to .env for local execution.
# Never commit populated local configuration.
# LLM_API_KEY is the public-safe variable used by API-enabled pipeline stages.

LLM_API_KEY=

# Optional provider model overrides.
LLM_SCENE_PRIMARY_MODEL=
LLM_SCENE_FALLBACK_MODEL=
LLM_REFINEMENT_MODEL=
LLM_EMBEDDING_MODEL=
LLM_EMBEDDING_MODEL_PUBLIC_NAME=provider_embedding_model_v1
